; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Hello Micro Bit XR"
config/description="Learn XR and code by playing with Micro:Bit and sensors."
run/main_scene="uid://c3hh5e2rll0p6"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[input]

test={
"deadzone": 0.2,
"events": []
}

[input_devices]

sensors/enable_accelerometer=true
sensors/enable_gravity=true
sensors/enable_gyroscope=true
sensors/enable_magnetometer=true

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="mobile"
environment/defaults/default_clear_color=Color(0, 0, 0, 0)

[xr]

openxr/enabled=true
openxr/default_action_map="uid://c4gq4811gjmy2"
openxr/reference_space=2
openxr/environment_blend_mode=2
openxr/extensions/hand_tracking=true
openxr/extensions/hand_tracking_unobstructed_data_source=true
openxr/extensions/hand_tracking_controller_data_source=true
openxr/extensions/hand_interaction_profile=true
openxr/extensions/eye_gaze_interaction=true
shaders/enabled=true
